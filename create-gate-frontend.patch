+// Gate de acceso ANTES de renderizar: evita el flash del editor a visitantes no
+// autenticados. Si no procede, canAccessApp() ya ha redirigido a login.
+canAccessApp().then((allowed) => {
+  if (!allowed) {
+    return;
+  }
+  root.render(
